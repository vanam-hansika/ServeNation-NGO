{
  "rewrites": [
    { "source": "/",           "destination": "/index.html" },
    { "source": "/about",      "destination": "/about.html" },
    { "source": "/works",      "destination": "/works.html" },
    { "source": "/volunteer",  "destination": "/volunteer.html" },
    { "source": "/gallery",    "destination": "/gallery.html" },
    { "source": "/contact",    "destination": "/contact.html" },
    { "source": "/admin-login", "destination": "/admin-login.html" },
    { "source": "/admin-dashboard", "destination": "/admin-dashboard.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
